# Database
DATABASE_URL=postgresql://admin:admin@localhost:5432/notification_platform

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin@localhost:5672/
RABBITMQ_EMAIL_QUEUE=email.send
RABBITMQ_STATUS_QUEUE=email.status

# Wiremock
WIREMOCK_URL=http://localhost:8089

# Email provider: "wiremock" (default, no real emails) or "sendgrid" (real emails)
EMAIL_PROVIDER=wiremock
# Required when EMAIL_PROVIDER=sendgrid:
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# SMS provider: "wiremock" (default, no real SMS) or "twilio" (real SMS)
SMS_PROVIDER=wiremock
# Required when SMS_PROVIDER=twilio:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
